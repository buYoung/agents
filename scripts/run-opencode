#!/usr/bin/env bash
#
# run-opencode
# ------------
# Test-oriented opencode CLI runner.
#
# This script is intentionally a thin wrapper around the real opencode binary.
# It loads this repository's packages/opencode plugin for each run, but it does
# not install the plugin permanently, mutate user/project opencode.json, or
# manage project configuration. Use the `agents` CLI for install/validate/doctor
# flows. This runner only normalizes execution for repeatable local test runs.
#
# Basic usage:
#   ./scripts/run-opencode --help
#   ./scripts/run-opencode run "Summarize this repository"
#   ./scripts/run-opencode run --model opencode/glm-5.2 "Inspect the code"
#   ./scripts/run-opencode run --model opencode/glm-5.2 --variant max "Inspect"
#
# Direct subagent harness:
#   ./scripts/run-opencode --direct-subagent code-explorer run "Inspect this repo"
#   ./scripts/run-opencode run --direct-subagent planner "Draft a plan"
#
#   This is a test-only harness for agent prompt improvement loops. opencode
#   normally rejects `mode: "subagent"` agents when passed through `run --agent`
#   because subagents are meant to be invoked by a primary agent through the
#   task tool. When --direct-subagent or OPENCODE_DIRECT_SUBAGENT is set, this
#   runner writes a per-run config override that temporarily changes only that
#   agent to `mode: "primary"` and sets it as default_agent. The real plugin
#   source stays unchanged; the override exists only inside .opencode-run/.
#
#   Valid direct agents:
#     orchestrator
#     intent-checker
#     worker
#     planner
#     research
#     code-explorer
#     idea-generator
#     adversarial-review
#     constructive-feedback
#
# Piped prompt usage:
#   printf '%s\n' "Summarize this repository" | ./scripts/run-opencode run
#
# Binary resolution order:
#   1. OPENCODE_CLI_PATH, when set. The path must be executable.
#   2. <repo>/node_modules/.bin/opencode, when present.
#   3. `opencode` from PATH.
#
# Working directory behavior:
#   The script always changes to the repository root before executing opencode.
#   This makes command behavior stable even when the script is called from a
#   subdirectory such as apps/ or packages/opencode/.
#
# Plugin behavior:
#   The runner writes a generated opencode config file:
#     .opencode-run/<run-id>/config/opencode.jsonc
#
#   That file injects this repository's plugin as a local plugin:
#     <repo>/packages/opencode/src/index.ts
#
#   It also enables the local codemap-search MCP server for runs:
#     "mcp": { "codemap-search": { "type": "local", "command": ["codemap-search", "mcp"], "enabled": true } }
#   Set OPENCODE_CODEMAP_MCP=0 to write a disabled override for no-MCP baseline
#   runs, including when user/global config also defines codemap-search.
#
#   When direct subagent mode is enabled, the generated config also includes:
#     default_agent: <direct-agent>
#     agent.<direct-agent>.mode: primary
#
#   When a run model is provided through --model/-m or OPENCODE_MODEL, the
#   generated config pins every bundled agent to that same model for the test
#   run. This keeps orchestrator-spawned subagents on the evaluated model.
#
#   The generated config file is exposed through OPENCODE_CONFIG so opencode
#   loads the plugin without mutating user or project config files. Project
#   opencode.json/opencode.jsonc files and normal config directories still load;
#   the runner only owns the custom config file used for plugin injection.
#
# Database isolation:
#   By default each invocation gets its own SQLite database:
#     .opencode-run/<run-id>/data/opencode.db
#
#   This avoids merging test sessions into the user's global opencode database
#   and avoids concurrent migration/write contention against a shared DB. The
#   path is passed through OPENCODE_DB. If OPENCODE_DB is already set, the script
#   preserves it and does not override it.
#
# Run artifact directory:
#   OPENCODE_RUN_ROOT defaults to:
#     <repo>/.opencode-run
#
#   OPENCODE_RUN_ID defaults to:
#     <YYYYMMDD-HHMMSS>-<pid>
#
#   Together they produce:
#     <OPENCODE_RUN_ROOT>/<OPENCODE_RUN_ID>/
#
# opencode run defaults:
#   For `opencode run`, this runner adds `--format json` by default unless the
#   caller already supplied `--format` or disabled the behavior with
#   OPENCODE_RUN_JSON=0. JSON output is easier to parse in benchmark/test
#   harnesses because tool events, text events, and token usage are structured.
#
# Model defaults:
#   OPENCODE_MODEL is appended as `--model <value>` for `opencode run` only when
#   neither --model nor -m is already present.
#
#   OPENCODE_MODEL_VARIANT is appended as `--variant <value>` for `opencode run`
#   only when --variant is not already present. Variants are provider-specific
#   reasoning/effort settings such as high, max, minimal, or xhigh. Unsupported
#   variants are validated by opencode itself.
#
# Environment variables:
#   OPENCODE_CLI_PATH=/path/to/opencode
#     Use a specific opencode executable instead of PATH resolution.
#
#   OPENCODE_RUN_ROOT=.opencode-run
#     Override the root directory used for runner artifacts.
#
#   OPENCODE_RUN_ID=my-run
#     Override the per-run directory name. Useful when reproducing a run.
#
#   OPENCODE_DB=/path/to/opencode.db
#     Override the isolated database path completely.
#
#   OPENCODE_MODEL=provider/model
#     Default model for `opencode run`.
#
#   OPENCODE_MODEL_VARIANT=max
#     Default model variant for `opencode run`.
#     When unset and the run model is openai/gpt-5.3-codex-spark, the runner
#     defaults to `low` so repeated eval runs do not inherit the provider's
#     heavier default reasoning budget. Explicit --variant or this variable
#     always wins.
#
#   OPENCODE_RUN_TITLE=<title>
#     Default title passed to `opencode run` when --title is not already present.
#     Set to 0 to disable title injection.
#
#   OPENCODE_RUN_JSON=0
#     Disable the default `--format json` injection.
#
#   OPENCODE_DIRECT_SUBAGENT=code-explorer
#     Enable the direct subagent harness without passing --direct-subagent.
#     Equivalent to:
#       ./scripts/run-opencode --direct-subagent code-explorer run ...
#
#   OPENCODE_CODEMAP_MCP=0
#     Disable generated codemap-search MCP config through an explicit disabled
#     override. Use this only for no-MCP baseline comparisons.
#
#   OPENCODE_AGENTS_PLUGIN=/path/to/plugin.ts
#     Override the local agents plugin entrypoint. Defaults to:
#     <repo>/packages/opencode/src/index.ts
#
#   OPENCODE_CONFIG_DIR=/path/to/opencode/config
#     Still passed through to opencode and to the packages/opencode plugin's
#     own config loader. The runner does not use it for plugin injection.
#
# Examples:
#   OPENCODE_MODEL=opencode/glm-5.2 \
#   OPENCODE_MODEL_VARIANT=max \
#   ./scripts/run-opencode run "Analyze this repository"
#
#   OPENCODE_RUN_ID=smoke-001 \
#   ./scripts/run-opencode run --format default "Interactive-style output"
#
#   OPENCODE_CLI_PATH=/Users/me/.opencode/bin/opencode \
#   ./scripts/run-opencode run --model openai/gpt-5.2 "Run with pinned binary"
#
#   ./scripts/run-opencode --direct-subagent adversarial-review \
#   run --model ollama-cloud/glm-5.2 "Review this proposed prompt"
#
# Notes:
#   - Explicit CLI arguments always win over environment defaults.
#   - OPENCODE_CONFIG is owned by this runner so packages/opencode is always
#     loaded as a plugin for the child opencode process.
#   - --direct-subagent is a runner-only flag. It is stripped before invoking
#     opencode.
#   - Direct subagent mode refuses pre-existing OPENCODE_CONFIG_CONTENT because
#     opencode merges that after OPENCODE_CONFIG and it can override the harness
#     config. Use project config files or OPENCODE_CONFIG_DIR for additive test
#     settings in this mode.
#   - Non-`run` commands still load the plugin, but are passed through without
#     model, variant, or format injection.
#   - .opencode-run/ is ignored by git.

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

has_arg() {
  local wanted="$1"
  shift
  local arg
  for arg in "$@"; do
    if [[ "${arg}" == "${wanted}" || "${arg}" == "${wanted}="* ]]; then
      return 0
    fi
  done
  return 1
}

arg_value() {
  local wanted="$1"
  shift
  local arg
  while (($# > 0)); do
    arg="$1"
    if [[ "${arg}" == "${wanted}="* ]]; then
      printf '%s\n' "${arg#*=}"
      return 0
    fi
    if [[ "${arg}" == "${wanted}" ]]; then
      if (($# < 2)); then
        return 1
      fi
      printf '%s\n' "$2"
      return 0
    fi
    shift
  done
  return 1
}

is_known_agent() {
  case "$1" in
    orchestrator | intent-checker | worker | planner | research | code-explorer | idea-generator | adversarial-review | constructive-feedback)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

direct_subagent="${OPENCODE_DIRECT_SUBAGENT:-}"
opencode_args=()
while (($# > 0)); do
  case "$1" in
    --direct-subagent)
      if (($# < 2)); then
        echo "--direct-subagent requires an agent name." >&2
        exit 2
      fi
      direct_subagent="$2"
      shift 2
      ;;
    --direct-subagent=*)
      direct_subagent="${1#*=}"
      shift
      ;;
    *)
      opencode_args+=("$1")
      shift
      ;;
  esac
done

if [[ -n "${direct_subagent}" ]]; then
  if ! is_known_agent "${direct_subagent}"; then
    echo "unknown direct subagent: ${direct_subagent}" >&2
    echo "valid agents: orchestrator intent-checker worker planner research code-explorer idea-generator adversarial-review constructive-feedback" >&2
    exit 2
  fi

  if [[ "${opencode_args[0]:-}" != "run" ]]; then
    echo "--direct-subagent is only supported with 'opencode run'." >&2
    exit 2
  fi

  if [[ -n "${OPENCODE_CONFIG_CONTENT:-}" ]]; then
    echo "--direct-subagent cannot be combined with OPENCODE_CONFIG_CONTENT." >&2
    echo "OPENCODE_CONFIG_CONTENT is merged after the runner config and can override the direct subagent harness." >&2
    exit 2
  fi

  explicit_agent="$(arg_value "--agent" "${opencode_args[@]}" || true)"
  if [[ -n "${explicit_agent}" && "${explicit_agent}" != "${direct_subagent}" ]]; then
    echo "--agent (${explicit_agent}) must match --direct-subagent (${direct_subagent})." >&2
    exit 2
  fi

  if [[ -z "${explicit_agent}" ]]; then
    opencode_args+=("--agent" "${direct_subagent}")
  fi
fi

if [[ -n "${OPENCODE_CLI_PATH:-}" ]]; then
  if [[ ! -x "${OPENCODE_CLI_PATH}" ]]; then
    echo "OPENCODE_CLI_PATH is not executable: ${OPENCODE_CLI_PATH}" >&2
    exit 1
  fi
  opencode_cli="$(
    cd -- "$(dirname -- "${OPENCODE_CLI_PATH}")"
    pwd
  )/$(basename -- "${OPENCODE_CLI_PATH}")"
elif [[ -x "${repo_root}/node_modules/.bin/opencode" ]]; then
  opencode_cli="${repo_root}/node_modules/.bin/opencode"
else
  opencode_cli="$(command -v opencode || true)"
  if [[ -z "${opencode_cli}" ]]; then
    echo "opencode CLI not found." >&2
    echo "Install opencode or set OPENCODE_CLI_PATH to the executable path." >&2
    exit 127
  fi
fi

opencode_run_root="${OPENCODE_RUN_ROOT:-${repo_root}/.opencode-run}"
opencode_run_id="${OPENCODE_RUN_ID:-$(date +%Y%m%d-%H%M%S)-$$}"
opencode_run_dir="${opencode_run_root}/${opencode_run_id}"
opencode_config_dir="${opencode_run_dir}/config"
opencode_config_file="${opencode_config_dir}/opencode.jsonc"
agents_plugin="${OPENCODE_AGENTS_PLUGIN:-${repo_root}/packages/opencode/src/index.ts}"

mkdir -p "${opencode_run_dir}/data" "${opencode_config_dir}"

if [[ ! -f "${agents_plugin}" ]]; then
  echo "agents plugin not found: ${agents_plugin}" >&2
  exit 1
fi

run_model_override=""
run_variant_override=""
if [[ "${opencode_args[0]:-}" == "run" ]]; then
  run_model_override="$(arg_value "--model" "${opencode_args[@]}" || true)"
  if [[ -z "${run_model_override}" ]]; then
    run_model_override="$(arg_value "-m" "${opencode_args[@]}" || true)"
  fi
  if [[ -z "${run_model_override}" && -n "${OPENCODE_MODEL:-}" ]]; then
    run_model_override="${OPENCODE_MODEL}"
  fi

  run_variant_override="$(arg_value "--variant" "${opencode_args[@]}" || true)"
  if [[ -z "${run_variant_override}" && -n "${OPENCODE_MODEL_VARIANT:-}" ]]; then
    run_variant_override="${OPENCODE_MODEL_VARIANT}"
  fi
  if [[ -z "${run_variant_override}" && "${run_model_override}" == "openai/gpt-5.3-codex-spark" ]]; then
    run_variant_override="low"
  fi
fi

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "${value}"
}

agent_config_block=""
if [[ -n "${direct_subagent}" || -n "${run_model_override}" ]]; then
  agent_config_block=$',
  "agent": {
'
  first_agent_entry=1
  for known_agent in orchestrator intent-checker worker planner research code-explorer idea-generator adversarial-review constructive-feedback; do
    if [[ -z "${run_model_override}" && "${known_agent}" != "${direct_subagent}" ]]; then
      continue
    fi

    if ((first_agent_entry == 0)); then
      agent_config_block+=$',
'
    fi
    first_agent_entry=0

    escaped_agent="$(json_escape "${known_agent}")"
    agent_config_block+="    \"${escaped_agent}\": {"

    first_property=1
    if [[ "${known_agent}" == "${direct_subagent}" ]]; then
      agent_config_block+="\"mode\": \"primary\""
      first_property=0
    fi
    if [[ -n "${run_model_override}" ]]; then
      if ((first_property == 0)); then
        agent_config_block+=", "
      fi
      escaped_model="$(json_escape "${run_model_override}")"
      agent_config_block+="\"model\": \"${escaped_model}\""
    fi
    agent_config_block+="}"
  done
  agent_config_block+=$'
  }'
fi

codemap_mcp_config=""
if [[ "${OPENCODE_CODEMAP_MCP:-1}" != "0" ]]; then
  codemap_mcp_config=',
  "mcp": {
    "codemap-search": {
      "type": "local",
      "command": ["codemap-search", "mcp"],
      "enabled": true
    }
  }'
else
  export OPENCODE_DISABLED_MCP_COMMANDS="${OPENCODE_DISABLED_MCP_COMMANDS:-codemap-search}"
  codemap_mcp_config=',
  "mcp": {
    "codemap-search": {
      "enabled": false
    }
  }'
fi

if [[ -n "${direct_subagent}" ]]; then
  cat > "${opencode_config_file}" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "plugin": [
    "${agents_plugin}"
  ]${codemap_mcp_config},
  "default_agent": "${direct_subagent}"${agent_config_block}
}
EOF
else
  cat > "${opencode_config_file}" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "plugin": [
    "${agents_plugin}"
  ]${codemap_mcp_config}${agent_config_block}
}
EOF
fi

export OPENCODE_DB="${OPENCODE_DB:-${opencode_run_dir}/data/opencode.db}"
export OPENCODE_CONFIG="${opencode_config_file}"

if [[ "${opencode_args[0]:-}" == "run" ]]; then
  if [[ -n "${OPENCODE_MODEL:-}" ]] && ! has_arg "--model" "${opencode_args[@]}" && ! has_arg "-m" "${opencode_args[@]}"; then
    opencode_args+=("--model" "${OPENCODE_MODEL}")
  fi

  if [[ -n "${run_variant_override}" ]] && ! has_arg "--variant" "${opencode_args[@]}"; then
    opencode_args+=("--variant" "${run_variant_override}")
  fi

  if [[ "${OPENCODE_RUN_TITLE:-${opencode_run_id}}" != "0" ]] && ! has_arg "--title" "${opencode_args[@]}"; then
    opencode_args+=("--title" "${OPENCODE_RUN_TITLE:-${opencode_run_id}}")
  fi

  if [[ "${OPENCODE_RUN_JSON:-1}" == "1" ]] && ! has_arg "--format" "${opencode_args[@]}"; then
    opencode_args+=("--format" "json")
  fi
fi

cd "${repo_root}"
if ((${#opencode_args[@]} > 0)); then
  exec "${opencode_cli}" "${opencode_args[@]}"
fi
exec "${opencode_cli}"
