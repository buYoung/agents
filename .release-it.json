{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "requireBranch": "main",
    "requireCleanWorkingDir": true,
    "requireUpstream": true,
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "agents v${version}",
    "autoGenerate": true,
    "assets": ["dist/release/*"]
  },
  "hooks": {
    "before:init": [
      "pnpm exec turbo run test --output-logs=full",
      "pnpm exec turbo run check-types --output-logs=full"
    ],
    "after:bump": [
      "node scripts/release/build.mjs --publish --version ${version} --tag v${version}",
      "node scripts/release/verify.mjs --directory dist/release --require-signature"
    ],
    "after:release": "node scripts/release/verify.mjs --remote --tag v${version} --require-signature"
  }
}
